# Database — SQLite for local dev, PostgreSQL for Railway
DATABASE_URL=sqlite:////tmp/constraint_ai.db

# Claude API key for AI cross-domain explanations
ANTHROPIC_API_KEY=sk-ant-api03-...

# Trace.Space integration (optional)
TRACESPACE_CLIENT_ID=
TRACESPACE_CLIENT_SECRET=
TRACESPACE_ORG=

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Auto-seed database on first startup (set to true on Railway)
AUTO_SEED=false
